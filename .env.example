# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Claude Model Configuration (optional)
# Latest model: claude-sonnet-4-5-20250929 (Claude Sonnet 4.5)
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_TEMPERATURE=0.7

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (required)
DATABASE_URL=postgresql://user:password@localhost:5432/rapid_launch_agent

# CORS Configuration (optional)
# For production, set this to your frontend URL
CORS_ORIGIN=*

# Clerk Authentication (optional - required for auth features)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
# CLERK_SECRET_KEY=sk_test_your-secret-key-here

# Development Overrides (optional)
# BYPASS_SUBSCRIPTION=true
# SKIP_RATE_LIMIT=true
